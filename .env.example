# ── Copy this to Render.com Environment Variables ──────────────────────────

# 1. Your custom verify token (make up any secret word, e.g. "mybridge2024")
VERIFY_TOKEN=mySecretToken123

# 2. WhatsApp Permanent Token (from Meta Developer > API Setup > Permanent Token)
WA_TOKEN=EAAxxxxxxxxxxxxxxxxx

# 3. Phone Number ID (from Meta Developer > API Setup)
WA_PHONE_ID=12345678901234

# 4. Voiceflow API Key (from Voiceflow > Settings > API Keys)
VF_API_KEY=VF.DM.xxxxxxxxxxxxxxxxx

# 5. Voiceflow version: "production" or "development"
VF_VERSION_ID=production

# Port (Render sets this automatically — don't change)
PORT=3000
